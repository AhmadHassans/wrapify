ADMIN_PASSWORD=wrapify2024
PORT=5050

# Comma-separated allowed origins for CORS. Use * to allow all (dev only).
CORS_ORIGIN=https://wrapifyoffical.com,http://localhost:5173

# AI bot — provider priority: Gemini > Groq > Ollama
# Set ONE of these. Gemini recommended for production.

# Google Gemini (free tier, most stable):
# Get key: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash

# Groq (free, fast — but blocks some datacenter IPs):
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# Ollama (local dev fallback if no API key):
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2:3b

# Public site URL (for payment callbacks)
PUBLIC_URL=https://wrapifyoffical.com

# Manual payment account details (shown to customer at checkout)
ACCOUNT_JAZZCASH_NAME=Wrapify Store
ACCOUNT_JAZZCASH_NUMBER=03XX-XXXXXXX
ACCOUNT_EASYPAISA_NAME=Wrapify Store
ACCOUNT_EASYPAISA_NUMBER=03XX-XXXXXXX
ACCOUNT_BANK_TITLE=Wrapify Store
ACCOUNT_BANK_NAME=Meezan Bank
ACCOUNT_BANK_IBAN=PK00MEZN0000000000000000
ACCOUNT_BANK_NUMBER=00000000000000

# (Optional) JazzCash merchant API credentials — only needed if using auto-redirect flow
JAZZCASH_MERCHANT_ID=
JAZZCASH_PASSWORD=
JAZZCASH_INTEGRITY_SALT=
JAZZCASH_MODE=sandbox

# (Optional) EasyPaisa merchant API credentials — only needed if using auto-redirect flow
EASYPAISA_STORE_ID=
EASYPAISA_HASH_KEY=
EASYPAISA_MODE=sandbox
