ADMIN_PASSWORD=wrapify2024
PORT=5050

# AI bot — provider priority: Gemini > Groq > Ollama
# Set ONE of these. Gemini recommended for production.

# Google Gemini (free tier, most stable):
# Get key: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash

# Groq (free, fast — but blocks some datacenter IPs):
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# Ollama (local dev fallback if no API key):
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2:3b

# Public site URL (for payment callbacks)
PUBLIC_URL=https://wrapifyoffical.com

# JazzCash merchant credentials (apply at jazzcash.com.pk/business)
JAZZCASH_MERCHANT_ID=
JAZZCASH_PASSWORD=
JAZZCASH_INTEGRITY_SALT=
JAZZCASH_MODE=sandbox

# EasyPaisa merchant credentials (apply at easypaisa.com.pk/business)
EASYPAISA_STORE_ID=
EASYPAISA_HASH_KEY=
EASYPAISA_MODE=sandbox
